{
  "name": "inertia-caseshift",
  "version": "0.1.2",
  "description": "Automatic snake_case <-> camelCase conversion for Inertia.js — the snake charmer for your props",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ tests/"
  },
  "keywords": [
    "inertia",
    "inertiajs",
    "camelCase",
    "snake_case",
    "rails",
    "laravel",
    "phoenix",
    "case-conversion"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skryukov/inertia-caseshift.git"
  },
  "homepage": "https://github.com/skryukov/inertia-caseshift",
  "bugs": "https://github.com/skryukov/inertia-caseshift/issues",
  "peerDependencies": {
    "@inertiajs/core": ">=3.0.0",
    "magic-string": ">=0.30.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@inertiajs/core": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "magic-string": {
      "optional": true
    }
  },
  "sideEffects": false,
  "devDependencies": {
    "@inertiajs/core": "^3.0.0",
    "acorn": "^8.0.0",
    "magic-string": "^0.30.0",
    "oxlint": "^1.58.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
